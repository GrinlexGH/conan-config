# clang-linux
[settings]
os=Linux
arch=x86_64
build_type=Release

compiler=clang
compiler.version=21
compiler.libcxx=libc++
compiler.cppstd=23
compiler.cstd=23

[conf]
tools.build:compiler_executables={ "c": "clang", "cpp": "clang++" }
tools.cmake.cmaketoolchain:extra_variables={ "CMAKE_INSTALL_RPATH": "$ORIGIN" }
tools.cmake.cmaketoolchain:generator=Ninja
