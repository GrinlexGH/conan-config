# gcc-linux
[settings]
os=Linux
arch=x86_64

build_type=Release
compiler=gcc
compiler.version=15.2
compiler.libcxx=libstdc++11
compiler.cppstd=23
compiler.cstd=23

[conf]
tools.build:compiler_executables={ "c": "gcc", "cpp": "g++" }
tools.cmake.cmaketoolchain:extra_variables={ "CMAKE_INSTALL_RPATH": "$ORIGIN" }
tools.cmake.cmaketoolchain:generator=Ninja
