# clang-clang64
{% import "mingw" as m with context %}

[settings]
os=Windows
arch=x86_64

build_type=Release
compiler=clang
compiler.version=22
compiler.libcxx=libc++
compiler.cppstd=23
compiler.cstd=23

[conf]
{{ m.conf("CLANG64", "clang.exe", "clang++.exe") }}
tools.cmake.cmaketoolchain:extra_variables={ "CMAKE_LINKER_TYPE": "LLD" }

[buildenv]
{{ m.buildenv("CLANG64") }}
